<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="ChessWPF.Views.MainMenuView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1A1A2E"
      Title="Главное меню">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Logo / Title -->
        <StackPanel Grid.Row="0"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,30">
            <TextBlock Text="&#x265F;"
                       FontSize="80"
                       Foreground="#E94560"
                       HorizontalAlignment="Center"
                       RenderTransformOrigin="0.5,0.5">
                <TextBlock.RenderTransform>
                    <RotateTransform Angle="-15"/>
                </TextBlock.RenderTransform>
            </TextBlock>

            <!-- Title with manual letter spacing via individual characters -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="Ш" FontSize="46" FontWeight="Bold"
                           Foreground="#EAEAEA" FontFamily="Segoe UI" Margin="3,0"/>
                <TextBlock Text="А" FontSize="46" FontWeight="Bold"
                           Foreground="#EAEAEA" FontFamily="Segoe UI" Margin="3,0"/>
                <TextBlock Text="Х" FontSize="46" FontWeight="Bold"
                           Foreground="#EAEAEA" FontFamily="Segoe UI" Margin="3,0"/>
                <TextBlock Text="М" FontSize="46" FontWeight="Bold"
                           Foreground="#EAEAEA" FontFamily="Segoe UI" Margin="3,0"/>
                <TextBlock Text="А" FontSize="46" FontWeight="Bold"
                           Foreground="#EAEAEA" FontFamily="Segoe UI" Margin="3,0"/>
                <TextBlock Text="Т" FontSize="46" FontWeight="Bold"
                           Foreground="#EAEAEA" FontFamily="Segoe UI" Margin="3,0"/>
                <TextBlock Text="Ы" FontSize="46" FontWeight="Bold"
                           Foreground="#EAEAEA" FontFamily="Segoe UI" Margin="3,0"/>
            </StackPanel>

            <TextBlock Text="Профессиональная шахматная программа"
                       FontSize="14"
                       Foreground="#A0A0B0"
                       FontFamily="Segoe UI"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Menu Buttons -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <Button Content="&#x265F;  Играть против ИИ"
                    Style="{StaticResource MenuButtonStyle}"
                    Click="BtnVsAI_Click"/>
            <Button Content="&#x2299;  Игра по локальной сети"
                    Style="{StaticResource MenuButtonStyle}"
                    Click="BtnLan_Click"/>
            <Button Content="&#x2715;  Выход"
                    Style="{StaticResource MenuButtonStyle}"
                    Background="#2A2A4A"
                    Click="BtnExit_Click"/>
        </StackPanel>

        <!-- Footer -->
        <TextBlock Grid.Row="2"
                   Text="v1.0.0  |  ChessWPF  |  2025"
                   Foreground="#404060"
                   FontSize="11"
                   FontFamily="Segoe UI"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,16"/>
    </Grid>
</Page>
