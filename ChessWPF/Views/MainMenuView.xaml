<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="ChessWPF.Views.MainMenuView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1A1A2E">

    <Grid>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <!-- Лого -->
            <TextBlock Text="♟" FontSize="80"
                       Foreground="#E94560"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8"/>

            <TextBlock FontSize="38" FontWeight="Bold"
                       FontFamily="Segoe UI" Foreground="#EAEAEA"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4">
                <TextBlock.Text>ChessWPF</TextBlock.Text>
            </TextBlock>

            <TextBlock x:Name="TxtWelcome"
                       FontSize="14" Foreground="#A0A0B0"
                       FontFamily="Segoe UI"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,36"/>

            <!-- Играть с ИИ -->
            <Button Click="BtnVsAI_Click"
                    Height="52" Width="320" Margin="0,8"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#E94560" CornerRadius="8">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="🤖" FontSize="20"
                                           Margin="0,0,10,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock FontSize="17" FontWeight="Bold"
                                           Foreground="White"
                                           FontFamily="Segoe UI"
                                           VerticalAlignment="Center">
                                    <TextBlock.Text>Играть с ИИ</TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#C73652"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Играть по сети -->
            <Button Click="BtnLan_Click"
                    Height="52" Width="320" Margin="0,8"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#2A2A4A" CornerRadius="8"
                                BorderThickness="1" BorderBrush="#4A4A7A">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="🌐" FontSize="20"
                                           Margin="0,0,10,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock FontSize="17" FontWeight="Bold"
                                           Foreground="#EAEAEA"
                                           FontFamily="Segoe UI"
                                           VerticalAlignment="Center">
                                    <TextBlock.Text>Играть по сети</TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3A3A6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Личный кабинет -->
            <Button Click="BtnProfile_Click"
                    Height="52" Width="320" Margin="0,8"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#2A2A4A" CornerRadius="8"
                                BorderThickness="1" BorderBrush="#4A4A7A">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="👤" FontSize="20"
                                           Margin="0,0,10,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock FontSize="17" FontWeight="Bold"
                                           Foreground="#EAEAEA"
                                           FontFamily="Segoe UI"
                                           VerticalAlignment="Center">
                                    <TextBlock.Text>Личный кабинет</TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3A3A6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- История партий -->
            <Button Click="BtnHistory_Click"
                    Height="52" Width="320" Margin="0,8"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#2A2A4A" CornerRadius="8"
                                BorderThickness="1" BorderBrush="#4A4A7A">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="📜" FontSize="20"
                                           Margin="0,0,10,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock FontSize="17" FontWeight="Bold"
                                           Foreground="#EAEAEA"
                                           FontFamily="Segoe UI"
                                           VerticalAlignment="Center">
                                    <TextBlock.Text>История партий</TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3A3A6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Головоломки -->
            <Button Click="BtnPuzzles_Click"
                    Height="52" Width="320" Margin="0,8"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#2A2A4A" CornerRadius="8"
                                BorderThickness="1" BorderBrush="#4A4A7A">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="🧩" FontSize="20"
                                           Margin="0,0,10,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock FontSize="17" FontWeight="Bold"
                                           Foreground="#EAEAEA"
                                           FontFamily="Segoe UI"
                                           VerticalAlignment="Center">
                                    <TextBlock.Text>Головоломки</TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3A3A6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Выход -->
            <Button Click="BtnExit_Click"
                    Height="44" Width="320" Margin="0,16,0,0"
                    Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent"
                                CornerRadius="6" BorderThickness="1"
                                BorderBrush="#3A3A5A">
                            <TextBlock FontSize="14" Foreground="#A0A0B0"
                                       FontFamily="Segoe UI"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Text>Выход</TextBlock.Text>
                            </TextBlock>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#E94560"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </StackPanel>
    </Grid>
</Page>
