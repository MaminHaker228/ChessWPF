<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="ChessWPF.Views.GameView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1A1A2E"
      Title="Игра">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <!-- Rank labels left -->
        <ItemsControl x:Name="RankLabels"
                      Grid.Column="0"
                      VerticalAlignment="Center"
                      Margin="8,0,4,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>

        <!-- Chess Board area -->
        <Grid Grid.Column="1"
              VerticalAlignment="Center"
              HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ItemsControl x:Name="FileLabels"
                          Grid.Row="0"
                          HorizontalAlignment="Center"/>
            <Canvas x:Name="BoardCanvas"
                    Grid.Row="1"
                    Width="560" Height="560"
                    MouseLeftButtonDown="BoardCanvas_MouseLeftButtonDown"
                    ClipToBounds="True"/>
        </Grid>

        <!-- Right panel -->
        <Border Grid.Column="2"
                Background="#16213E"
                CornerRadius="10"
                Margin="8"
                Padding="12">
            <StackPanel>
                <TextBlock x:Name="TxtStatus"
                           Text="Ваш ход"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="#E94560"
                           FontFamily="Segoe UI"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"
                           HorizontalAlignment="Center"/>
                <Separator Background="#2A2A4A" Margin="0,0,0,12"/>

                <TextBlock Text="Захвачено (чёрные):"
                           Foreground="#A0A0B0"
                           FontSize="11"
                           FontFamily="Segoe UI"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="TxtCapturedBlack"
                           Text=""
                           Foreground="#EAEAEA"
                           FontSize="16"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"/>

                <TextBlock Text="Захвачено (белые):"
                           Foreground="#A0A0B0"
                           FontSize="11"
                           FontFamily="Segoe UI"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="TxtCapturedWhite"
                           Text=""
                           Foreground="#EAEAEA"
                           FontSize="16"
                           TextWrapping="Wrap"
                           Margin="0,0,0,20"/>

                <Separator Background="#2A2A4A" Margin="0,0,0,12"/>

                <TextBlock Text="История ходов:"
                           Foreground="#A0A0B0"
                           FontSize="11"
                           FontFamily="Segoe UI"
                           Margin="0,0,0,4"/>
                <ScrollViewer Height="220"
                              VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtMoveHistory"
                               Foreground="#EAEAEA"
                               FontFamily="Consolas"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </ScrollViewer>

                <Separator Background="#2A2A4A" Margin="0,12"/>

                <TextBlock x:Name="TxtNetInfo"
                           Text=""
                           Foreground="#A0A0B0"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"/>

                <Button Content="&#x2190; Главное меню"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="BtnMenu_Click"
                        Height="36"
                        Margin="0,4"/>
                <Button Content="Новая игра"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="BtnNewGame_Click"
                        Height="36"
                        Margin="0,4"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
