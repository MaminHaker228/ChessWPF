<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="ChessWPF.Views.TimeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Time"
        Width="400" Height="470"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A2E"
        ResizeMode="NoResize">
    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="30">

        <!-- Заголовок -->
        <TextBlock FontSize="22"
                   FontWeight="Bold"
                   FontFamily="Segoe UI"
                   Foreground="#EAEAEA"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,6">
            <TextBlock.Text>Выберите время</TextBlock.Text>
        </TextBlock>

        <TextBlock FontSize="13"
                   FontFamily="Segoe UI"
                   Foreground="#A0A0B0"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20">
            <TextBlock.Text>Время на каждого игрока</TextBlock.Text>
        </TextBlock>

        <!-- 1 минута -->
        <Button Click="Btn1_Click" Height="52" Width="300"
                Margin="0,5" Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="#2A2A4A"
                            CornerRadius="8" BorderThickness="1"
                            BorderBrush="#4A4A7A">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="&#x26A1;"
                                       FontSize="20" Margin="0,0,12,0"
                                       VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock FontSize="16" FontWeight="Bold"
                                           Foreground="White" FontFamily="Segoe UI">
                                    <TextBlock.Text>1 минута</TextBlock.Text>
                                </TextBlock>
                                <TextBlock FontSize="11"
                                           Foreground="#A0A0B0" FontFamily="Segoe UI">
                                    <TextBlock.Text>Bullet — молниеносная игра</TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#3A3A6A"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- 3 минуты -->
        <Button Click="Btn3_Click" Height="52" Width="300"
                Margin="0,5" Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="#2A2A4A"
                            CornerRadius="8" BorderThickness="1"
                            BorderBrush="#4A4A7A">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="&#x1F525;"
                                       FontSize="20" Margin="0,0,12,0"
                                       VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock FontSize="16" FontWeight="Bold"
                                           Foreground="White" FontFamily="Segoe UI">
                                    <TextBlock.Text>3 минуты</TextBlock.Text>
                                </TextBlock>
                                <TextBlock FontSize="11"
                                           Foreground="#A0A0B0" FontFamily="Segoe UI">
                                    <TextBlock.Text>Blitz — быстрые шахматы</TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#3A3A6A"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- 5 минут -->
        <Button Click="Btn5_Click" Height="52" Width="300"
                Margin="0,5" Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="#E94560"
                            CornerRadius="8" BorderThickness="0">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="&#x23F0;"
                                       FontSize="20" Margin="0,0,12,0"
                                       VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock FontSize="16" FontWeight="Bold"
                                           Foreground="White" FontFamily="Segoe UI">
                                    <TextBlock.Text>5 минут</TextBlock.Text>
                                </TextBlock>
                                <TextBlock FontSize="11"
                                           Foreground="#FFCCCC" FontFamily="Segoe UI">
                                    <TextBlock.Text>Blitz — популярный формат</TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#C73652"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- 10 минут -->
        <Button Click="Btn10_Click" Height="52" Width="300"
                Margin="0,5" Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="#2A2A4A"
                            CornerRadius="8" BorderThickness="1"
                            BorderBrush="#4A4A7A">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="&#x1F9E0;"
                                       FontSize="20" Margin="0,0,12,0"
                                       VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock FontSize="16" FontWeight="Bold"
                                           Foreground="White" FontFamily="Segoe UI">
                                    <TextBlock.Text>10 минут</TextBlock.Text>
                                </TextBlock>
                                <TextBlock FontSize="11"
                                           Foreground="#A0A0B0" FontFamily="Segoe UI">
                                    <TextBlock.Text>Rapid — обдуманная игра</TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#3A3A6A"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Без таймера -->
        <Button Click="BtnNoTimer_Click" Height="44" Width="300"
                Margin="0,10,0,0" Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="Transparent"
                            CornerRadius="6" BorderThickness="1"
                            BorderBrush="#3A3A5A">
                        <TextBlock FontSize="14" Foreground="#A0A0B0"
                                   FontFamily="Segoe UI"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Text>Без таймера</TextBlock.Text>
                        </TextBlock>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="#E94560"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

    </StackPanel>
</Window>
