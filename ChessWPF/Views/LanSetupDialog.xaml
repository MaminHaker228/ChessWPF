<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="ChessWPF.Views.LanSetupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LAN Setup"
        Width="400" Height="340"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A2E"
        ResizeMode="NoResize">
    <StackPanel Margin="30">

        <TextBlock FontSize="20"
                   FontWeight="Bold"
                   Foreground="#EAEAEA"
                   FontFamily="Segoe UI"
                   Margin="0,0,0,20">
            <TextBlock.Text>Игра по локальной сети</TextBlock.Text>
        </TextBlock>

        <Button Click="BtnHost_Click"
                Height="44"
                Width="300"
                Margin="0,4"
                Cursor="Hand"
                Background="#E94560"
                Foreground="White"
                FontFamily="Segoe UI"
                FontSize="16">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#C73652"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
            <TextBlock Text="Создать игру (Хост)" Foreground="White" FontSize="16"/>
        </Button>

        <Separator Background="#2A2A4A" Margin="0,12"/>

        <TextBlock Foreground="#A0A0B0"
                   FontFamily="Segoe UI"
                   FontSize="13"
                   Margin="0,0,0,6">
            <TextBlock.Text>Подключиться к игре:</TextBlock.Text>
        </TextBlock>

        <TextBox x:Name="TxtIP"
                 Text="192.168.1.100"
                 Background="#16213E"
                 Foreground="#EAEAEA"
                 BorderBrush="#4A4A7A"
                 FontSize="14"
                 Padding="8,6"
                 FontFamily="Consolas"
                 Margin="0,0,0,8"/>

        <Button Click="BtnConnect_Click"
                Height="44"
                Width="300"
                Margin="0,4"
                Cursor="Hand"
                Background="#2A2A4A"
                Foreground="#EAEAEA"
                FontFamily="Segoe UI"
                FontSize="14">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            BorderThickness="1"
                            BorderBrush="#4A4A7A">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="12,0"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#3A3A6A"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
            <TextBlock Text="Подключиться" Foreground="#EAEAEA" FontSize="14"/>
        </Button>

    </StackPanel>
</Window>
