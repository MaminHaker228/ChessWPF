<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="ChessWPF.Views.GameOverDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Game Over"
        Width="360" Height="220"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A2E"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background"  Value="#E94560"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="16"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#C73652"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2A2A4A"/>
            <Setter Property="Foreground" Value="#EAEAEA"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="14"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                BorderThickness="1"
                                BorderBrush="#4A4A7A">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="12,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3A3A6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock x:Name="TxtResult"
                   Text="MAT!"
                   FontSize="36"
                   FontWeight="Bold"
                   Foreground="#E94560"
                   FontFamily="Segoe UI"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,8"/>
        <TextBlock x:Name="TxtMessage"
                   Text=""
                   FontSize="16"
                   Foreground="#EAEAEA"
                   FontFamily="Segoe UI"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,24"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="BtnNewGameBtn"
                    Content="Новая игра"
                    Style="{StaticResource MenuButtonStyle}"
                    Width="150" Height="44"
                    Margin="6"
                    Click="BtnNewGame_Click"/>
            <Button x:Name="BtnMenuBtn"
                    Content="Главное меню"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Width="150" Height="44"
                    Margin="6"
                    Click="BtnMenu_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
