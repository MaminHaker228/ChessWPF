<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="ChessWPF.Views.HistoryView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1A1A2E">

    <StackPanel MaxWidth="620" HorizontalAlignment="Center"
                Margin="30,30,30,30">

        <TextBlock FontSize="26" FontWeight="Bold"
                   FontFamily="Segoe UI" Foreground="#EAEAEA"
                   HorizontalAlignment="Center" Margin="0,0,0,24">
            <TextBlock.Text>История партий</TextBlock.Text>
        </TextBlock>

        <ItemsControl x:Name="GameList"/>

        <Button Click="BtnBack_Click" Height="46"
                Margin="0,24,0,0" Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="#E94560" CornerRadius="8">
                        <TextBlock FontSize="15" FontWeight="Bold"
                                   Foreground="White" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Text>← Главное меню</TextBlock.Text>
                        </TextBlock>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#C73652"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

    </StackPanel>
</Page>
