<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="ChessWPF.Views.PuzzleView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1A1A2E">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="240"/>
        </Grid.ColumnDefinitions>

        <!-- Доска -->
        <Grid Grid.Column="0" HorizontalAlignment="Center"
              VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <StackPanel Grid.Row="0" Margin="24,0,0,12">
                <TextBlock x:Name="TxtPuzzleTitle"
                           FontSize="20" FontWeight="Bold"
                           Foreground="#EAEAEA" FontFamily="Segoe UI"/>
                <TextBlock x:Name="TxtPuzzleDesc"
                           FontSize="13" Foreground="#A0A0B0"
                           FontFamily="Segoe UI"/>
            </StackPanel>

            <!-- Доска -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ItemsControl x:Name="RankLabels"
                              Grid.Column="0" Grid.Row="0"
                              VerticalAlignment="Top"/>
                <Canvas x:Name="BoardCanvas"
                        Grid.Column="1" Grid.Row="0"
                        Width="480" Height="480"
                        MouseLeftButtonDown="BoardCanvas_Click"/>
                <ItemsControl x:Name="FileLabels"
                              Grid.Column="1" Grid.Row="1"
                              Margin="0,2,0,0"/>
            </Grid>

            <!-- Статус -->
            <Border Grid.Row="2" Background="#16213E"
                    CornerRadius="8" Padding="14,10"
                    Margin="24,12,0,0">
                <TextBlock x:Name="TxtStatus"
                           FontSize="16" FontWeight="Bold"
                           Foreground="#E94560"
                           FontFamily="Segoe UI"
                           HorizontalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- Правая панель -->
        <StackPanel Grid.Column="1" Margin="8,16,16,16">

            <!-- Сложность -->
            <Border Background="#16213E" CornerRadius="8"
                    Padding="12" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Foreground="#A0A0B0" FontSize="11"
                               FontFamily="Segoe UI">
                        <TextBlock.Text>Сложность</TextBlock.Text>
                    </TextBlock>
                    <TextBlock x:Name="TxtDifficulty"
                               FontSize="16" FontWeight="Bold"
                               Foreground="#F39C12"
                               FontFamily="Segoe UI"/>
                </StackPanel>
            </Border>

            <!-- Прогресс -->
            <Border Background="#16213E" CornerRadius="8"
                    Padding="12" Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Foreground="#A0A0B0" FontSize="11"
                               FontFamily="Segoe UI">
                        <TextBlock.Text>Прогресс</TextBlock.Text>
                    </TextBlock>
                    <TextBlock x:Name="TxtProgress"
                               FontSize="15" FontWeight="Bold"
                               Foreground="#EAEAEA"
                               FontFamily="Segoe UI"/>
                </StackPanel>
            </Border>

            <!-- Подсказка -->
            <Button x:Name="BtnHint" Click="BtnHint_Click"
                    Height="42" Margin="0,0,0,6" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#2A2A4A"
                                CornerRadius="8" BorderThickness="1"
                                BorderBrush="#F39C12">
                            <TextBlock FontSize="14" Foreground="#F39C12"
                                       FontFamily="Segoe UI"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Text>💡 Подсказка</TextBlock.Text>
                            </TextBlock>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3A3A1A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Следующая -->
            <Button x:Name="BtnNext" Click="BtnNext_Click"
                    Height="42" Margin="0,0,0,6" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#E94560" CornerRadius="8">
                            <TextBlock FontSize="14" FontWeight="Bold"
                                       Foreground="White" FontFamily="Segoe UI"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Text>Следующая →</TextBlock.Text>
                            </TextBlock>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#C73652"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Сбросить -->
            <Button x:Name="BtnReset" Click="BtnReset_Click"
                    Height="42" Margin="0,0,0,16" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="#2A2A4A"
                                CornerRadius="8" BorderThickness="1"
                                BorderBrush="#4A4A7A">
                            <TextBlock FontSize="14" Foreground="#EAEAEA"
                                       FontFamily="Segoe UI"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Text>↺ Сначала</TextBlock.Text>
                            </TextBlock>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3A3A6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Меню -->
            <Button Click="BtnMenu_Click" Height="42" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent"
                                CornerRadius="6" BorderThickness="1"
                                BorderBrush="#3A3A5A">
                            <TextBlock FontSize="13" Foreground="#A0A0B0"
                                       FontFamily="Segoe UI"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.Text>← Главное меню</TextBlock.Text>
                            </TextBlock>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#E94560"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </StackPanel>
    </Grid>
</Page>
