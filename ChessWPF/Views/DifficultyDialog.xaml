<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="ChessWPF.Views.DifficultyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Difficulty"
        Width="380" Height="370"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A2E"
        ResizeMode="NoResize">
    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Margin="30">

        <!-- Заголовок -->
        <TextBlock FontSize="22"
                   FontWeight="Bold"
                   FontFamily="Segoe UI"
                   Foreground="#EAEAEA"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,6">
            <TextBlock.Text>Выберите режим игры</TextBlock.Text>
        </TextBlock>

        <TextBlock FontSize="13"
                   FontFamily="Segoe UI"
                   Foreground="#A0A0B0"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,24">
            <TextBlock.Text>Выберите сложность противника</TextBlock.Text>
        </TextBlock>

        <!-- Лёгкий -->
        <Button Click="BtnEasy_Click"
                Height="52" Width="300"
                Margin="0,6"
                Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="#27AE60"
                            CornerRadius="8">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="&#x1F7E2;"
                                       FontSize="18"
                                       Margin="0,0,10,0"
                                       VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           FontFamily="Segoe UI">
                                    <TextBlock.Text>Лёгкий</TextBlock.Text>
                                </TextBlock>
                                <TextBlock FontSize="11"
                                           Foreground="#CCFFCC"
                                           FontFamily="Segoe UI">
                                    <TextBlock.Text>Глубина поиска: 1</TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#219A52"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Средний -->
        <Button Click="BtnMedium_Click"
                Height="52" Width="300"
                Margin="0,6"
                Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="#F39C12"
                            CornerRadius="8">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="&#x1F7E1;"
                                       FontSize="18"
                                       Margin="0,0,10,0"
                                       VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           FontFamily="Segoe UI">
                                    <TextBlock.Text>Средний</TextBlock.Text>
                                </TextBlock>
                                <TextBlock FontSize="11"
                                           Foreground="#FFF0CC"
                                           FontFamily="Segoe UI">
                                    <TextBlock.Text>Глубина поиска: 3</TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#D68910"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Сложный -->
        <Button Click="BtnHard_Click"
                Height="52" Width="300"
                Margin="0,6"
                Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="#E94560"
                            CornerRadius="8">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="&#x1F534;"
                                       FontSize="18"
                                       Margin="0,0,10,0"
                                       VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           FontFamily="Segoe UI">
                                    <TextBlock.Text>Сложный</TextBlock.Text>
                                </TextBlock>
                                <TextBlock FontSize="11"
                                           Foreground="#FFCCCC"
                                           FontFamily="Segoe UI">
                                    <TextBlock.Text>Глубина поиска: 5</TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#C73652"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

    </StackPanel>
</Window>
